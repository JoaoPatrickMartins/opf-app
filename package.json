{
  "name": "opf-app",
  "version": "1.0.0",
  "private": true,
  "description": "OPF — app pessoal de consciência financeira",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",

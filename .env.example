# Groq API — usada para classificação automática de gastos na importação.
# Obtenha em https://console.groq.com/keys
# Também pode ser configurada pela tela de Configurações do app.
GROQ_API_KEY=

# Portas dos servidores de desenvolvimento (opcionais).
BACKEND_PORT=3008
FRONTEND_PORT=5179

# MongoDB Atlas — banco de dados principal do app.
# Formato: mongodb+srv://<usuario>:<senha>@<cluster>/?retryWrites=true&w=majority&appName=<app>
MONGODB_URI=
MONGODB_DB=opf
